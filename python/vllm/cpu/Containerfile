# C.f. https://docs.vllm.ai/en/stable/getting_started/installation/cpu/#set-up-using-python
FROM python:3.12-slim

ARG CONTAINER_UID=1000
ARG CONTAINER_GID=1000
ARG VLLM_VERSION=0.19.0

# install TCMalloc, Intel OpenMP is installed with vLLM CPU
RUN apt-get update && apt-get install -y --no-install-recommends \
    libtcmalloc-minimal4 \
    libomp-19-dev \
    libnuma1 \
    build-essential \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Create a non-root user.
RUN groupadd --gid ${CONTAINER_GID} user \
 && useradd --uid ${CONTAINER_UID} --gid ${CONTAINER_GID} --no-log-init --shell /bin/bash --create-home user

# Switch to the non-root user.
# Sets the default container user (containerUser). Even when remoteUser is defined in devcontainer.json,
# this ensures the container runs as non-root in all contexts (e.g. direct docker run, CI/CD pipelines).
USER user

WORKDIR /workdir

# Make Python commands available in all processes (CMD uses exec form, so ~/.bashrc is never sourced).
ENV PATH="/home/user/.local/bin:${PATH}"

# To manually find and update the path
# sudo find / -iname *libtcmalloc_minimal.so.4
# sudo find / -iname *libiomp5.so
ENV TC_PATH="/usr/lib/x86_64-linux-gnu/libtcmalloc_minimal.so.4"
ENV IOMP_PATH="/usr/lib/x86_64-linux-gnu/libiomp5.so"

# Add them to LD_PRELOAD
ENV LD_PRELOAD="${TC_PATH}:${IOMP_PATH}:${LD_PRELOAD}"

RUN pip install --user --no-cache-dir --upgrade pip
RUN pip install --user https://github.com/vllm-project/vllm/releases/download/v${VLLM_VERSION}/vllm-${VLLM_VERSION}+cpu-cp38-abi3-manylinux_2_35_x86_64.whl --extra-index-url https://download.pytorch.org/whl/cpu
