FROM debian:stable-slim

ARG CONTAINER_UID=1000
ARG CONTAINER_GID=1000

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    chromium \
    curl \
    gh \
    git \
    neovim \
    npm \
    pipx \
    python3-pip \
    ripgrep \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid ${CONTAINER_GID} user \
 && useradd --uid ${CONTAINER_UID} --gid ${CONTAINER_GID} --no-log-init --create-home user
USER user

# Make `claude` available in all processes (CMD uses exec form, so ~/.bashrc is never sourced)
ENV PATH="/home/user/.local/bin:${PATH}"

WORKDIR /workspace

CMD ["claude"]
